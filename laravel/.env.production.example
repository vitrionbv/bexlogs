# BexLogs — production environment template.
#
# The `deploy/bootstrap.sh` script will copy this to `laravel/.env`, fill in
# random secrets, and substitute APP_DOMAIN. After bootstrap you can edit
# laravel/.env directly to tweak any of these.
#
# Anything marked CHANGE ME is filled in by the bootstrap script. Anything
# marked TODO is left for you to fill in by hand if you need it.

# ── Caddy / TLS ────────────────────────────────────────────────────────────
# The fully-qualified domain Caddy will request a Let's Encrypt cert for.
# Must have a public DNS A record pointing at this server before the first
# `docker compose up`, or Caddy will fall back to its self-signed cert.
APP_DOMAIN=CHANGE_ME.example.com
APP_ACME_EMAIL=admin@CHANGE_ME.example.com

# ── Laravel core ───────────────────────────────────────────────────────────
APP_NAME=BexLogs
APP_ENV=production
APP_KEY=CHANGE_ME
APP_DEBUG=false
APP_URL=https://CHANGE_ME.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ── Database (internal docker net) ─────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=bexlogs
DB_USERNAME=bexlogs
DB_PASSWORD=CHANGE_ME

# ── Sessions / cache / queue ───────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true  # Laravel infers this from APP_URL=https://; uncomment to force.

CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

# ── Redis (internal docker net) ────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ── Broadcasting (Reverb / Pusher protocol) ────────────────────────────────
BROADCAST_CONNECTION=reverb

# Public-facing — what the JS client and Pusher SDK connect to. These three
# get baked into the Vite build via VITE_REVERB_*.
REVERB_HOST=CHANGE_ME.example.com
REVERB_PORT=443
REVERB_SCHEME=https

# Internal — what `php artisan reverb:start` binds to inside the container.
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Application credentials. Bootstrap generates random values.
REVERB_APP_ID=CHANGE_ME
REVERB_APP_KEY=CHANGE_ME
REVERB_APP_SECRET=CHANGE_ME

# Echo / Pusher SDK reads these at Vite build time. Bootstrap script mirrors
# REVERB_* into VITE_REVERB_* so the build picks the right values up — these
# placeholders are overwritten end-to-end and don't rely on `${VAR}` style
# interpolation (compose env_file substitutes from the host shell, not the
# file itself).
VITE_REVERB_APP_KEY=CHANGE_ME
VITE_REVERB_HOST=CHANGE_ME.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_APP_NAME=BexLogs

# ── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@CHANGE_ME.example.com"
MAIL_FROM_NAME="BexLogs"

# ── BexLogs scraper / extension ────────────────────────────────────────────
# Bearer token shared between Laravel and the Playwright scraper container.
WORKER_API_TOKEN=CHANGE_ME

# Scraper tuning (consumed by the scraper container).
POLL_INTERVAL_MS=5000
MAX_CONCURRENT_SCRAPES=2
MAX_PAGES_PER_JOB=2000
BATCH_SIZE=100

# BookingExperts URLs.
BEX_BASE_URL_PRODUCTION=https://app.bookingexperts.com
BEX_BASE_URL_STAGING=https://app.staging.bookingexperts.com

# Browser-extension version pin (filled in from extension/manifest.json by
# the bootstrap script). Used by ExtensionController::download to set the
# X-Extension-Version header and the suggested update prompt.
EXTENSION_VERSION=
EXTENSION_MIN_VERSION=

# ── AWS placeholders (unused; required by Laravel config defaults) ─────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── IP allowlist ───────────────────────────────────────────────────────────
# Comma-separated list of CIDRs / literal IPs allowed to reach the app.
# Empty (the default) = open to anyone. The `/up` healthcheck and
# `/api/worker/*` (scraper, Bearer-token authed) are always exempt.
#
# After changing this, re-run `php artisan config:cache` in the app
# container — or restart it — so the new value is picked up.
#
# Defense-in-depth options that are independent of this middleware:
#   1. Cloudflare WAF rule. From the Cloudflare dashboard → Security → WAF,
#      add a custom rule with action "Block" and the expression:
#          (http.host eq "bexlogs.vitrion.dev") and not (ip.src in {YOUR.IP.HERE})
#      That stops attackers at Cloudflare's edge instead of at our origin.
#   2. UFW + Cloudflare's published edge IP list. `ufw allow from <CF_IP>
#      to any port 443` (and 80) for every range in
#      https://www.cloudflare.com/ips/, then `ufw deny 80,443`. Forces all
#      origin traffic through Cloudflare.
#
# Example: APP_IP_ALLOWLIST=203.0.113.10,198.51.100.0/24
APP_IP_ALLOWLIST=
