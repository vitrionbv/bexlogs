# BexLogs Laravel base URL (no trailing slash).
LARAVEL_BASE_URL=http://localhost:8000

# Bearer token; must match Laravel's WORKER_API_TOKEN.
WORKER_API_TOKEN=change-me-in-production-please

# Polling interval for fetching the next job (ms).
POLL_INTERVAL_MS=5000

# Cadence for the per-job heartbeat ticker (ms). The Node loop POSTs to
# /api/worker/jobs/{id}/heartbeat at this interval for the entire lifetime
# of an in-flight job, independent of batch flushes. Must stay below
# Laravel's `scrape:reap-stale --minutes` threshold (default 3 minutes).
HEARTBEAT_INTERVAL_MS=30000

# Max number of scrape jobs run in parallel by this worker.
MAX_CONCURRENT_SCRAPES=8

# Hard cap on number of paginated requests per scrape job (defensive).
MAX_PAGES_PER_JOB=2000

# Hard cap on number of rows POSTed per batch.
BATCH_SIZE=100

# Run the browser non-headless (for debugging).
HEADLESS=true
